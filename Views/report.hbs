<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>ADAS Calibration Report</title>
  <style>
    :root {
      --gold: #f1b82d;
      --navy: #0a131e;
      --white: #ffffff;
      --light-gray: #f5f5f5;
      --dark-gray: #333333;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    @page { size: A4; margin: 0.4in; }
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-size: 11px; line-height: 1.3; color: var(--dark-gray); }
    .header { display: flex; align-items: center; margin-bottom: 8px; padding-bottom: 6px; border-bottom: 2px solid var(--gold); gap: 10px; }
    .logo img { height: 50px; }
    .header-content h1 { font-size: 16px; color: var(--navy); font-weight: 600; }
    .vehicle-info { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; margin-bottom: 8px; padding: 6px; background: var(--light-gray); font-size: 10px; border-radius: 3px; }
    .vehicle-info-item label { font-weight: 600; color: var(--navy); font-size: 9px; margin-bottom: 1px; }
    .systems-section { margin-bottom: 8px; padding: 6px; background: var(--light-gray); border-radius: 3px; }
    .systems-section h3 { font-size: 11px; color: var(--navy); margin-bottom: 4px; font-weight: 600; }
    .systems-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px; }
    .system-item { font-size: 10px; padding: 2px 0; border-left: 2px solid var(--gold); padding-left: 4px; }
    .summary-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; margin-bottom: 8px; }
    .summary-card { background: linear-gradient(135deg, var(--navy) 0%, #1a2332 100%); color: var(--white); padding: 6px; border-radius: 3px; text-align: center; border-top: 3px solid var(--gold); }
    .summary-card-value { font-size: 18px; font-weight: 700; color: var(--gold); }
    .section { margin-bottom: 8px; padding: 6px; border-left: 3px solid var(--gold); background: var(--light-gray); border-radius: 2px; }
    .section h2 { font-size: 12px; color: var(--navy); margin-bottom: 4px; font-weight: 600; }
    .calibrations-table { width: 100%; border-collapse: collapse; font-size: 10px; }
    .calibrations-table th { background: var(--navy); color: var(--white); padding: 4px; font-weight: 600; font-size: 9px; }
    .calibrations-table td { padding: 4px; border-bottom: 1px solid #ddd; }
    .calibrations-table tr:nth-child(even) { background: #fafafa; }
    .badge-static { background: #e3f2fd; color: #0d47a1; padding: 2px 4px; border-radius: 2px; font-size: 8px; font-weight: 600; }
    .footer { margin-top: 8px; padding-top: 6px; border-top: 1px solid var(--gold); font-size: 9px; display: flex; justify-content: space-between; }
    .footer a { color: var(--gold); text-decoration: none; }
  </style>
</head>
<body>
  <div class="header">
    <div class="logo"><img src="https://res.cloudinary.com/dk64e0k8t/image/upload/v1775582262/Adas_logo_2_transparent.png_1_fcjm2x.png" alt="ADAS Logo"></div>
    <div class="header-content"><h1>ADAS Calibration Report</h1></div>
  </div>
  <div class="vehicle-info">
    <div class="vehicle-info-item"><label>VIN</label><value>{{vehicle.vin}}</value></div>
    <div class="vehicle-info-item"><label>Year</label><value>{{vehicle.year}}</value></div>
    <div class="vehicle-info-item"><label>Make</label><value>{{vehicle.make}}</value></div>
    <div class="vehicle-info-item"><label>Model</label><value>{{vehicle.model}}</value></div>
    <div class="vehicle-info-item"><label>I-CAR Reference</label><value>{{vehicle.icar_article}}</value></div>
  </div>
  {{#if adas_systems_present}}<div class="systems-section"><h3>ADAS Systems Present</h3><div class="systems-grid"><div class="system-list">{{#each adas_systems_present}}<div class="system-item">{{this}}</div>{{/each}}</div></div></div>{{/if}}
  {{#if safety_systems_present}}<div class="systems-section"><h3>Safety Systems Present</h3><div class="systems-grid"><div class="system-list">{{#each safety_systems_present}}<div class="system-item">{{this}}</div>{{/each}}</div></div></div>{{/if}}
  {{#if brake_systems}}<div class="systems-section"><h3>Brake Systems</h3><div class="systems-grid"><div class="system-list">{{#each brake_systems}}<div class="system-item">{{this}}</div>{{/each}}</div></div></div>{{/if}}
  <div class="summary-cards">
    <div class="summary-card"><div class="summary-card-label">Total Calibrations</div><div class="summary-card-value">{{calibrations_required.length}}</div></div>
    <div class="summary-card"><div class="summary-card-label">Static</div><div class="summary-card-value">{{static_calibrations_count}}</div></div>
    <div class="summary-card"><div class="summary-card-label">Dynamic</div><div class="summary-card-value">{{dynamic_calibrations_count}}</div></div>
    <div class="summary-card"><div class="summary-card-label">Other</div><div class="summary-card-value">{{aim_calibrations_count}}</div></div>
  </div>
  {{#if calibrations_required}}<div class="section"><h2>Calibrations Required</h2><table class="calibrations-table"><thead><tr><th style="width: 20%;">System</th><th style="width: 15%;">Type</th><th style="width: 35%;">Trigger</th><th style="width: 30%;">Requirement</th></tr></thead><tbody>{{#each calibrations_required}}<tr><td><strong>{{this.system}}</strong></td><td><span class="badge-static">{{this.calibration_type}}</span></td><td>{{this.trigger}}</td><td>{{this.icar_requirement}}</td></tr>{{#if this.notes}}<tr style="background: #fffafb;"><td colspan="4" style="font-size: 9px; font-style: italic; padding: 2px 4px;">📌 {{this.notes}}</td></tr>{{/if}}{{/each}}</tbody></table></div>{{/if}}
  <div class="footer"><div class="footer-left"><a href="https://rts.i-car.com" target="_blank">I-CAR RTS Database</a> | Calibration procedures verified</div><div class="footer-center">Generated: {{generated_date}} at {{generated_time}}</div><div class="footer-right">v{{report_version}}</div></div>
</body>
</html>
